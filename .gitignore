# ── Python ────────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
*.pyd
*.egg-info/
dist/
build/
.eggs/
*.so

# ── Virtual environments ───────────────────────────────────────────────────────
.venv/
venv/
env/
.conda/

# ── Large data files ───────────────────────────────────────────────────────────
# ocean_obs.nc is ~80 MB; use scripts/download_data.py to obtain it
data/ocean_obs.nc
*.nc.tmp

# ── Jupyter ────────────────────────────────────────────────────────────────────
.ipynb_checkpoints/
*/.ipynb_checkpoints/

# ── Generated figures (reproducible from notebooks/scripts) ───────────────────
figures/*.png
figures/*.pdf
figures/*.svg
figures/*.gif
figures/*.mp4
!figures/.gitkeep

# ── macOS ──────────────────────────────────────────────────────────────────────
.DS_Store
.AppleDouble
.LSOverride
*.swp

# ── IDE ────────────────────────────────────────────────────────────────────────
.vscode/settings.json
.idea/
*.iml

# ── Test / coverage ────────────────────────────────────────────────────────────
.pytest_cache/
.coverage
htmlcov/
coverage.xml
